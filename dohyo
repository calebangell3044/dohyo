}}>
Top Winning Techniques This Basho
</div>
{stats.map(([name, count]) => (
<div key={name} style={{
display: “grid”, gridTemplateColumns: “1fr auto”,
gap: “0.5rem”, alignItems: “center”,
padding: “0.4rem 0.5rem”,
