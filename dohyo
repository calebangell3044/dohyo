function KimariteStats({ torikumiByDay, maxDay }) {
const stats = useMemo(() => {
const counts = {};
for (let d = 1; d <= maxDay; d++) {
const matches = torikumiByDay[d] || [];
for (const m of matches) {
if (m.kimarite) {
counts[m.kimarite] = (counts[m.kimarite] || 0) + 1;
}
}
}
return Object.entries(counts)
.sort((a, b) => b[1] - a[1])
.slice(0, 15);
}, [torikumiByDay, maxDay]);

if (stats.length === 0) return <ErrorMessage message="No kimarite data available yet." />;

const maxCount = stats[0]?.[1] || 1;

return (
<div style={{ padding: “0.5rem” }}>
<div style={{
fontFamily: “‘Noto Sans JP’, sans-serif”,
fontSize: “0.65rem”, color: “#5a5248”,
textTransform: “uppercase”, letterSpacing: “0.1em”,
