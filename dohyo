function LeaderboardView({ banzuke, torikumiByDay, maxDay, onSelectRikishi }) {
const records = useMemo(() => {
const map = {};
// Initialize from banzuke
if (banzuke) {
for (const entry of banzuke) {
const id = entry.rikishiId || entry.rikishi_id;
if (!id) continue;
map[id] = {
id,
name: entry.shikona || entry.shikonaEn || “Unknown”,
rank: entry.rank || “”,
wins: 0, losses: 0, absent: 0,
};
}
}
// Tally from match results
for (let d = 1; d <= maxDay; d++) {
const matches = torikumiByDay[d];
if (!matches) continue;
for (const m of matches) {
if (!m.winnerId) continue;
// East
if (m.eastId) {
if (!map[m.eastId]) {
map[m.eastId] = { id: m.eastId, name: m.eastShikona || “?”, rank: m.eastRank || “”, wins: 0, losses: 0, absent: 0 };
}
if (m.winnerId === m.eastId) map[m.eastId].wins++;
else map[m.eastId].losses++;
}
// West
if (m.westId) {
if (!map[m.westId]) {
map[m.westId] = { id: m.westId, name: m.westShikona || “?”, rank: m.westRank || “”, wins: 0, losses: 0, absent: 0 };
}
if (m.winnerId === m.westId) map[m.westId].wins++;
else map[m.westId].losses++;
}
}
}
return Object.values(map).sort((a, b) => {
const winDiff = (b.wins - b.losses) - (a.wins - a.losses);
if (winDiff !== 0) return winDiff;
if (b.wins !== a.wins) return b.wins - a.wins;
return rankIndex(a.rank) - rankIndex(b.rank);
});
}, [banzuke, torikumiByDay, maxDay]);

if (records.length === 0) return <ErrorMessage message="No standings data available yet." />;

return (
<div style={{ padding: “0 0.5rem” }}>
<div style={{
display: “grid”, gridTemplateColumns: “auto 1fr auto auto”,
gap: “0 0.75rem”, alignItems: “center”,
padding: “0.5rem 0.75rem”,
borderBottom: “1px solid #2d271f”,
fontFamily: “‘Noto Sans JP’, sans-serif”,
fontSize: “0.6rem”, color: “#5a5248”,
textTransform: “uppercase”, letterSpacing: “0.1em”,
}}>
<div>#</div><div>Rikishi</div><div>W-L</div><div style={{ width: 60 }}></div>
</div>
{records.map((r, i) => {
const total = r.wins + r.losses;
const pct = total > 0 ? r.wins / total : 0;
const tier = rankTier(r.rank);
const tierColors = {
yokozuna: “#d4a843”,
ozeki: “#c47a3a”,
sanyaku: “#8a7d6b”,
maegashira: “#5a5248”,
};
return (
<div
key={r.id}
onClick={() => onSelectRikishi(r.id, r.name)}
style={{
display: “grid”, gridTemplateColumns: “auto 1fr auto auto”,
gap: “0 0.75rem”, alignItems: “center”,
padding: “0.6rem 0.75rem”,
borderBottom: “1px solid rgba(45,39,31,0.5)”,
cursor: “pointer”,
transition: “background 0.15s”,
}}
onMouseEnter={e => e.currentTarget.style.background = “rgba(191,161,104,0.05)”}
onMouseLeave={e => e.currentTarget.style.background = “transparent”}
>
<div style={{
fontFamily: “‘Noto Sans JP’, sans-serif”,
fontSize: “0.75rem”, color: i < 3 ? “#d4a843” : “#5a5248”,
fontWeight: i < 3 ? 700 : 400, minWidth: 24,
}}>
{i + 1}
</div>
<div>
<div style={{
fontFamily: “‘Crimson Text’, serif”,
fontSize: “1rem”, color: “#c9bca8”, fontWeight: 600,
}}>
{r.name}
</div>
<div style={{
fontFamily: “‘Noto Sans JP’, sans-serif”,
fontSize: “0.6rem”, color: tierColors[tier],
textTransform: “uppercase”, letterSpacing: “0.05em”,
}}>
{rankShort(r.rank)}
</div>
</div>
<div style={{
fontFamily: “‘Noto Sans JP’, sans-serif”,
fontSize: “0.9rem”, fontWeight: 600,
color: r.wins > r.losses ? “#7aa86b” : r.wins < r.losses ? “#a86b6b” : “#8a7d6b”,
}}>
{r.wins}-{r.losses}
</div>
<div style={{ width: 60, height: 6, background: “#2d271f”, borderRadius: 3, overflow: “hidden” }}>
<div style={{
width: `${pct * 100}%`, height: “100%”, borderRadius: 3,
background: pct >= 0.5
? `linear-gradient(90deg, #5a7a4a, #7aa86b)`
: `linear-gradient(90deg, #a86b6b, #7a4a4a)`,
transition: “width 0.3s ease”,
}} />
</div>
</div>
);
})}
</div>
);
}

